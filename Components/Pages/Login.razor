@page "/login"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject AuthService Auth
@inject ThemeService Theme
@inject IJSRuntime JS
@implements IDisposable
@using System.ComponentModel.DataAnnotations

<div class="login-page @(Theme.IsDark ? "dark" : "")"
     style="--primary:@Theme.PrimaryColor;--primary-dark:@Theme.PrimaryDark();--primary-15:@Theme.PrimaryAlpha(0.15);--primary-30:@Theme.PrimaryAlpha(0.30)">

    <GiwuThemeToggle/>

    <div class="login-center">
        <div class="login-card">
            <div class="card-heading">
                <p>Sign in to your account to continue</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <GiwuEmailField @bind-Value="loginModel.Email"
                                Label="Email address"
                                Required="true"
                                For="@(() => loginModel.Email)"
                                Class="mb-3" />

                <GiwuPasswordField @bind-Value="loginModel.Password"
                                   Required="true"
                                   For="@(() => loginModel.Password)"
                                   Class="mb-2" />

                <div class="form-row">
                    <GiwuCheckbox @bind-Value="loginModel.RememberMe" Label="Remember me" />
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <GiwuButton ButtonType="ButtonType.Submit" FullWidth="true" Class="signin-btn-mud">Sign In</GiwuButton>
            </EditForm>

            <div class="login-footer">
                Don't have an account? <a href="#" class="signup-link">Sign up</a>
            </div>

        </div>
    </div>

    <div class="watermark-wrap">
        <GiwuWatermark />
    </div>

</div>

@code {
    private LoginModel loginModel = new();

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn) Navigation.NavigateTo("/");
        Theme.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await ApplyTheme();
    }

    private void HandleLogin()
    {
        Auth.Login(loginModel.Email);
        Navigation.NavigateTo("/");
    }

    private Task ApplyTheme() =>
        JS.InvokeVoidAsync("document.documentElement.setAttribute",
            "data-theme", Theme.IsDark ? "dark" : "light").AsTask();

    public void Dispose() => Theme.OnChange -= StateHasChanged;

    public class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}

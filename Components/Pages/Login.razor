@page "/login"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject AuthService Auth
@inject ThemeService Theme
@inject IJSRuntime JS
@implements IDisposable
@using System.ComponentModel.DataAnnotations

<div class="login-page @(Theme.IsDark ? "dark" : "")"
     style="--primary:@Theme.PrimaryColor;--primary-dark:@Theme.PrimaryDark();--primary-15:@Theme.PrimaryAlpha(0.15);--primary-30:@Theme.PrimaryAlpha(0.30)">

    <button class="theme-toggle" @onclick="ToggleDark" title="Toggle theme">
        @if (Theme.IsDark)
        {
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.1 3.1l1.1 1.1M11.8 11.8l1.1 1.1M12.9 3.1l-1.1 1.1M4.2 11.8l-1.1 1.1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        }
        else
        {
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A6 6 0 0 1 6.5 2.5a6 6 0 1 0 7 7z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        }
    </button>

    <div class="login-center">
        <div class="login-card">
            <div class="card-heading">
                <p>Sign in to your account to continue</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="field-group">
                    <label class="field-label">Email address</label>
                    <InputText @bind-Value="loginModel.Email"
                               class="field-input rounded"
                               placeholder="you@company.com" />
                    <ValidationMessage For="@(() => loginModel.Email)" />
                </div>

                <div class="field-group">
                    <label class="field-label">Password</label>
                    <InputText @bind-Value="loginModel.Password"
                               type="password"
                               class="field-input rounded"
                               placeholder="••••••••" />
                    <ValidationMessage For="@(() => loginModel.Password)" />
                </div>

                <div class="form-row">
                    <label class="remember-label">
                        <InputCheckbox @bind-Value="loginModel.RememberMe" />
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button class="signin-btn" type="submit">Sign In</button>
            </EditForm>

            <div class="login-footer">
                Don't have an account? <a href="#" class="signup-link">Sign up</a>
            </div>

        </div>
    </div>

    <div class="watermark-wrap">
        <GiwuWatermark IsDark="@Theme.IsDark" />
    </div>

</div>

@code {
    private LoginModel loginModel = new();

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn) Navigation.NavigateTo("/");
        Theme.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await ApplyTheme();
    }

    private void HandleLogin()
    {
        Auth.Login(loginModel.Email);
        Navigation.NavigateTo("/");
    }

    private async Task ToggleDark()
    {
        Theme.SetDark(!Theme.IsDark);
        await ApplyTheme();
    }

    private Task ApplyTheme() =>
        JS.InvokeVoidAsync("document.documentElement.setAttribute",
            "data-theme", Theme.IsDark ? "dark" : "light").AsTask();

    public void Dispose() => Theme.OnChange -= StateHasChanged;

    public class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}

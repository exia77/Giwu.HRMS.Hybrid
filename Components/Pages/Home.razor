@page "/"
@layout DashboardLayout

@*Home Screen*@
<MudGrid Spacing="2">

  @* ── Stat cards ── *@
  @foreach (var s in _stats)
  {
    <MudItem xs="12" sm="6" md="3">
      <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid var(--mud-palette-divider);border-radius:10px">
        <MudText Typo="Typo.caption" Style="opacity:.65">@s.Label</MudText>
        <MudText Typo="Typo.h5" Class="my-1 fw-bold">@s.Value</MudText>
        <MudText Typo="Typo.caption" Style="@($"color:{s.ChangeColor}")">@s.Change</MudText>
      </MudPaper>
    </MudItem>
  }

  @* ── Recent employees ── *@
  <MudItem xs="12" md="6">
    <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid var(--mud-palette-divider);border-radius:10px">
      <MudText Typo="Typo.subtitle1" Class="mb-3 fw-semibold">
        Recent employees
        <MudText Inline="true" Typo="Typo.caption" Style="opacity:.55;margin-left:6px">last 30 days</MudText>
      </MudText>

      @foreach (var e in _employees)
      {
        <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--mud-palette-divider)">
          <MudAvatar Style="@($"background:{e.AvatarBg};color:{e.AvatarFg};font-size:.75rem;width:32px;height:32px")">@e.Initials</MudAvatar>
          <div style="flex:1;min-width:0">
            <MudText Typo="Typo.body2" Class="fw-medium" Style="line-height:1.2">@e.Name</MudText>
            <MudText Typo="Typo.caption" Style="opacity:.55">@e.Dept</MudText>
          </div>
          <MudChip T="string" Size="Size.Small" Color="@e.ChipColor" Variant="Variant.Filled" Style="height:22px;font-size:.7rem">@e.Status</MudChip>
        </div>
      }
    </MudPaper>
  </MudItem>

  @* ── Leave requests ── *@
  <MudItem xs="12" md="6">
    <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid var(--mud-palette-divider);border-radius:10px">
      <MudText Typo="Typo.subtitle1" Class="mb-3 fw-semibold">
        Leave requests
        <MudText Inline="true" Typo="Typo.caption" Style="opacity:.55;margin-left:6px">pending</MudText>
      </MudText>

      @foreach (var l in _leaveRequests)
      {
        <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--mud-palette-divider)">
          <div style="flex:1;min-width:0">
            <MudText Typo="Typo.body2" Class="fw-medium" Style="line-height:1.2">@l.Name</MudText>
            <MudText Typo="Typo.caption" Style="opacity:.55">@l.DateRange</MudText>
          </div>
          <MudChip T="string" Size="Size.Small" Color="@l.ChipColor" Variant="Variant.Filled" Style="height:22px;font-size:.7rem">@l.Status</MudChip>
        </div>
      }
    </MudPaper>
  </MudItem>

  @* ── Headcount by dept ── *@
  <MudItem xs="12" md="4">
    <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid var(--mud-palette-divider);border-radius:10px;height:100%">
      <MudText Typo="Typo.subtitle1" Class="mb-3 fw-semibold">Headcount by dept</MudText>

      @foreach (var d in _depts)
      {
        <div style="margin-bottom:12px">
          <div style="display:flex;justify-content:space-between;margin-bottom:4px">
            <MudText Typo="Typo.caption">@d.Name</MudText>
            <MudText Typo="Typo.caption" Style="opacity:.65">@d.Count</MudText>
          </div>
          <MudProgressLinear Value="@d.Pct" Color="@d.Color" Rounded="true" Size="Size.Small" />
        </div>
      }
    </MudPaper>
  </MudItem>

  @* ── Quick actions ── *@
  <MudItem xs="12" md="8">
    <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid var(--mud-palette-divider);border-radius:10px;height:100%">
      <MudText Typo="Typo.subtitle1" Class="mb-3 fw-semibold">Quick actions</MudText>

      <MudGrid Spacing="2">
        @foreach (var a in _actions)
        {
          <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-3 d-flex align-center gap-3" Elevation="0"
                      Style="@($"border:1px solid var(--mud-palette-divider);border-radius:8px;cursor:pointer;background:{a.IconBg}10")"
                      @onclick="() => Navigate(a.Path)">
              <MudAvatar Style="@($"background:{a.IconBg};border-radius:8px;width:32px;height:32px")" Rounded="true">
                @((MarkupString)a.SvgIcon)
              </MudAvatar>
              <div style="min-width:0">
                <MudText Typo="Typo.body2" Class="fw-medium" Style="line-height:1.2">@a.Label</MudText>
                <MudText Typo="Typo.caption" Style="opacity:.55">@a.Desc</MudText>
              </div>
            </MudPaper>
          </MudItem>
        }
      </MudGrid>
    </MudPaper>
  </MudItem>
</MudGrid>

@code {

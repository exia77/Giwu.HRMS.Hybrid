    record EmpRow(string Initials, string AvatarBg, string AvatarFg, string Name, string Dept, string Status, Color ChipColor);
    record LeaveRow(string Name, string DateRange, string Status, Color ChipColor);
    record DeptBar(string Name, int Count, double Pct, Color Color);
    record QuickAction(string Label, string Desc, string Path, string IconBg, string SvgIcon);


@* ── Delete Department Dialog ── *@
<MudDialog>
    <TitleContent>
        <div style="display:flex;align-items:center;gap:10px">
            <div style="width:36px;height:36px;background:#FCEBEB;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                    <path d="M2 4h12M5 4V2.5a.5.5 0 01.5-.5h5a.5.5 0 01.5.5V4M6 7v5M10 7v5M3 4l.8 9.5a.5.5 0 00.5.5h7.4a.5.5 0 00.5-.5L13 4"
                          stroke="#C62828" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div>
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;line-height:1.2;color:#C62828">
                    Delete Department
                </MudText>
                <MudText Typo="Typo.caption" Style="opacity:.55">This action cannot be undone</MudText>
            </div>
        </div>
    </TitleContent>

    <DialogContent>
        @* Dept preview *@
        <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border:1px solid var(--mud-palette-divider);border-radius:10px;margin-bottom:16px;background:var(--mud-palette-background-grey)">
            <div style="@($"width:38px;height:38px;border-radius:9px;background:{IconBg};display:flex;align-items:center;justify-content:center;flex-shrink:0")">
                @((MarkupString)Icon)
            </div>
            <div style="flex:1">
                <MudText Typo="Typo.body2" Style="font-weight:700;line-height:1.2">@DeptName</MudText>
                <MudText Typo="Typo.caption" Style="opacity:.5">@Headcount members</MudText>
            </div>
            <div style="@($"width:8px;height:8px;border-radius:50%;background:{Color}")"></div>
        </div>

        @* Warning *@
        <div style="display:flex;gap:10px;padding:12px 14px;background:#FFF5F5;border:1px solid #FECACA;border-radius:8px;margin-bottom:12px">
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16" style="flex-shrink:0;margin-top:1px">
                <path d="M8 1.5L1 14h14L8 1.5z" stroke="#C62828" stroke-width="1.3" stroke-linejoin="round"/>
                <line x1="8" y1="6.5" x2="8" y2="10" stroke="#C62828" stroke-width="1.3" stroke-linecap="round"/>
                <circle cx="8" cy="12" r=".6" fill="#C62828"/>
            </svg>
            <MudText Typo="Typo.caption" Style="color:#C62828;line-height:1.5">
                Deleting <strong>@DeptName</strong> will permanently remove the department
                and unassign all <strong>@Headcount members</strong>. This cannot be reversed.
            </MudText>
        </div>

        @* Confirmation checkbox *@
        <MudCheckBox @bind-Value="_confirmed" Dense="true">
            <MudText Typo="Typo.caption">
                I understand this will permanently delete this department
            </MudText>
        </MudCheckBox>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" Style="text-transform:none" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="MudBlazor.Color.Error"
                   Style="text-transform:none;border-radius:8px"
                   StartIcon="@Icons.Material.Outlined.Delete"
                   OnClick="Confirm" Disabled="!_confirmed">
            Delete Department
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string DeptName  { get; set; } = "";
    [Parameter] public int    Headcount { get; set; }
    [Parameter] public string Color     { get; set; } = "";
    [Parameter] public string IconBg    { get; set; } = "";
    [Parameter] public string Icon      { get; set; } = "";

    bool _confirmed;

    void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    void Cancel()  => MudDialog.Cancel();
}

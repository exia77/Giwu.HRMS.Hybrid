<MudTextField T="string"
              Label="@Label"
              Value="@Value"
              ValueChanged="@ValueChanged"
              Placeholder="@Placeholder"
              HelperText="@HelperText"
              Required="@Required"
              RequiredError="@RequiredError"
              Disabled="@Disabled"
              Variant="Variant.Outlined"
              FullWidth="true"
              InputType="@_inputType"
              Adornment="Adornment.End"
              AdornmentIcon="@_icon"
              OnAdornmentClick="ToggleVisibility"
              AdornmentAriaLabel="Toggle password visibility"
              For="@For"
              Class="@Class" />

@code {
    private bool _showPassword;
    private InputType _inputType => _showPassword ? InputType.Text : InputType.Password;
    private string _icon => _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    [Parameter] public string Label { get; set; } = "Password";
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "••••••••";
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string RequiredError { get; set; } = "Password is required.";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public Expression<Func<string>>? For { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private void ToggleVisibility() => _showPassword = !_showPassword;
}

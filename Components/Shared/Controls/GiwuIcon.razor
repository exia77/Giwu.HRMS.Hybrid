@code {
    [Parameter] public string Name { get; set; } = "";
}

@switch (Name)
{
    case "EmptyCompanyImage":
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="3" fill="white"/>
            <line x1="8" y1="1" x2="8" y2="4" stroke="white" stroke-width="1.5"/>
            <line x1="8" y1="12" x2="8" y2="15" stroke="white" stroke-width="1.5"/>
            <line x1="1" y1="8" x2="4" y2="8" stroke="white" stroke-width="1.5"/>
            <line x1="12" y1="8" x2="15" y2="8" stroke="white" stroke-width="1.5"/>
            <line x1="3" y1="3" x2="5.2" y2="5.2" stroke="white" stroke-width="1.2"/>
            <line x1="10.8" y1="10.8" x2="13" y2="13" stroke="white" stroke-width="1.2"/>
            <line x1="13" y1="3" x2="10.8" y2="5.2" stroke="white" stroke-width="1.2"/>
            <line x1="5.2" y1="10.8" x2="3" y2="13" stroke="white" stroke-width="1.2"/>
          </svg>
    break;

case "Employees":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.3"/>
                <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
        break;

        case "Departments":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <circle cx="5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="11" cy="5" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M1 13c0-2.8 1.8-4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <path d="M15 13c0-2.8-1.8-4-4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <path d="M5.5 9.5C6.3 9.2 7.1 9 8 9s1.7.2 2.5.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            break;

        case "Attendance":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M5 3V1.5M11 3V1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="2" y1="6.5" x2="14" y2="6.5" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="5.5" cy="10" r="1" fill="currentColor"/>
                <circle cx="8" cy="10" r="1" fill="currentColor"/>
                <circle cx="10.5" cy="10" r="1" fill="currentColor"/>
            </svg>
            break;

        case "Recruitment":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <path d="M8 2L9.5 6h4.5l-3.6 2.6 1.4 4.4L8 10.5 4.2 13l1.4-4.4L2 6h4.5z"
                      stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            </svg>
            break;

        case "Payroll":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <rect x="1.5" y="3" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                <line x1="1.5" y1="6.5" x2="14.5" y2="6.5" stroke="currentColor" stroke-width="1.3"/>
                <line x1="5" y1="10" x2="7" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            break;

        case "Benefits":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <path d="M8 1v14M5 4.5C5 3.1 6.3 2 8 2s3 1.1 3 2.5S9.7 7 8 7s-3 1.1-3 2.5S6.3 12 8 12s3-1.1 3-2.5"
                      stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            break;

        case "Leave":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <path d="M13 8a5 5 0 1 1-10 0 5 5 0 0 1 10 0z" stroke="currentColor" stroke-width="1.3"/>
                <path d="M8 5.5V8l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            break;

        case "Reports":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <path d="M13 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z"
                      stroke="currentColor" stroke-width="1.3"/>
                <path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            break;
        case "Settings":
            <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.3"/>
                <path d="M8 1.5v1.8M8 12.7v1.8M1.5 8h1.8M12.7 8h1.8"
                      stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <path d="M3.4 3.4l1.3 1.3M11.3 11.3l1.3 1.3M12.6 3.4l-1.3 1.3M4.7 11.3l-1.3 1.3"
                      stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
        break;

}
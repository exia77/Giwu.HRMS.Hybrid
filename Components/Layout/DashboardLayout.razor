@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ThemeService Theme
@inject AuthService Auth
@inject IJSRuntime JS
@implements IDisposable

<MudLayout>

  @* ── Sidebar drawer ── *@
  <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0"
             Style="border-right:1px solid var(--mud-palette-divider)">

    <MudDrawerHeader Style="padding:16px 20px;border-bottom:1px solid var(--mud-palette-divider)">
      <div style="display:flex;align-items:center;gap:10px">
        <div class="brand-icon @(!string.IsNullOrEmpty(Theme.LogoDataUrl) ? "has-logo" : "")">
          @if (!string.IsNullOrEmpty(Theme.LogoDataUrl))
          {
            <img src="@Theme.LogoDataUrl" class="brand-logo-sm" alt="logo" />
          }
          else
          {
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="3" fill="white"/>
              <line x1="8" y1="1" x2="8" y2="4" stroke="white" stroke-width="1.5"/>
              <line x1="8" y1="12" x2="8" y2="15" stroke="white" stroke-width="1.5"/>
              <line x1="1" y1="8" x2="4" y2="8" stroke="white" stroke-width="1.5"/>
              <line x1="12" y1="8" x2="15" y2="8" stroke="white" stroke-width="1.5"/>
              <line x1="3" y1="3" x2="5.2" y2="5.2" stroke="white" stroke-width="1.2"/>
              <line x1="10.8" y1="10.8" x2="13" y2="13" stroke="white" stroke-width="1.2"/>
              <line x1="13" y1="3" x2="10.8" y2="5.2" stroke="white" stroke-width="1.2"/>
              <line x1="5.2" y1="10.8" x2="3" y2="13" stroke="white" stroke-width="1.2"/>
            </svg>
          }
        </div>
        <MudText Typo="Typo.subtitle1" Class="fw-bold" Style="line-height:1">@Theme.CompanyName</MudText>
      </div>
    </MudDrawerHeader>

    <MudNavMenu>
      <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-1"
               Style="opacity:.5;font-size:.65rem;letter-spacing:.08em">Main</MudText>

      <MudNavLink Href="/" Match="NavLinkMatch.All"
                  Icon="@Icons.Material.Outlined.GridView">Dashboard</MudNavLink>

      <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-1"
               Style="opacity:.5;font-size:.65rem;letter-spacing:.08em">People</MudText>

      <MudNavLink Href="/employees"   Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.Person">Employees</MudNavLink>
      <MudNavLink Href="/departments" Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.Groups">Departments</MudNavLink>
      <MudNavLink Href="/attendance"  Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.CalendarMonth">
        <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
          Attendance
          <MudChip T="string" Size="Size.Small" Color="Color.Error"
                   Variant="Variant.Filled" Style="height:18px;font-size:.65rem;min-width:unset;padding:0 6px">3</MudChip>
        </div>
      </MudNavLink>
      <MudNavLink Href="/recruitment" Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.WorkOutline">Recruitment</MudNavLink>

      <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-1"
               Style="opacity:.5;font-size:.65rem;letter-spacing:.08em">Payroll</MudText>

      <MudNavLink Href="/payroll"  Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.CreditCard">Payroll</MudNavLink>
      <MudNavLink Href="/benefits" Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.VolunteerActivism">Benefits</MudNavLink>

      <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-1"
               Style="opacity:.5;font-size:.65rem;letter-spacing:.08em">More</MudText>

      <MudNavLink Href="/leave" Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.Schedule">
        <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
          Leave &amp; Time Off
          <MudChip T="string" Size="Size.Small" Color="Color.Error"
                   Variant="Variant.Filled" Style="height:18px;font-size:.65rem;min-width:unset;padding:0 6px">5</MudChip>
        </div>
      </MudNavLink>
      <MudNavLink Href="/reports"  Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.Description">Reports</MudNavLink>
      <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix"
                  Icon="@Icons.Material.Outlined.Settings">Settings</MudNavLink>
    </MudNavMenu>

    <MudSpacer />

    <div style="padding:14px 16px;border-top:1px solid var(--mud-palette-divider);
                display:flex;align-items:center;gap:10px">
      <MudAvatar Style="width:30px;height:30px;font-size:.72rem" Color="Color.Primary">JD</MudAvatar>
      <div style="flex:1;min-width:0">
        <MudText Typo="Typo.body2" Class="fw-semibold" Style="line-height:1.2">Jane Dela Cruz</MudText>
        <MudText Typo="Typo.caption" Style="opacity:.55">HR Manager</MudText>
      </div>
    </div>

  </MudDrawer>

  @* ── Top app bar ── *@
  <MudAppBar Elevation="0"
             Style="border-bottom:1px solid var(--mud-palette-divider);background:var(--mud-palette-background)">
    <div style="flex:1">
      <MudText Typo="Typo.h6" Class="fw-semibold" Style="line-height:1.1">@TopbarTitle</MudText>
      <MudText Typo="Typo.caption" Style="opacity:.55">@Today.ToString("dddd, MMMM d, yyyy")</MudText>
    </div>
    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="font-size:.7rem">
      Q2 · Week @WeekNumber
    </MudChip>
    <GiwuThemeToggle ButtonClass="theme-toggle-inline" />
    <MudIconButton Icon="@Icons.Material.Outlined.Notifications" Size="Size.Small" />
    <MudAvatar Style="width:30px;height:30px;font-size:.72rem;cursor:pointer;margin-left:4px"
               Color="Color.Primary">JD</MudAvatar>
  </MudAppBar>
  @* ── Page content ── *@
    <MudMainContent>
        <div style="padding:24px">
            @Body
        </div>
    </MudMainContent>
    <div class="watermark-wrap">
        <GiwuWatermark />
    </div>
</MudLayout>

@code {
    private string RelPath => Navigation.ToBaseRelativePath(Navigation.Uri);

    private string TopbarTitle => RelPath.StartsWith("settings", StringComparison.OrdinalIgnoreCase)
        ? "Settings"
        : $"Good {Greeting}, Jane";

    private string Greeting => DateTime.Now.Hour < 12 ? "morning"
        : DateTime.Now.Hour < 17 ? "afternoon" : "evening";

    private DateTime Today => DateTime.Now;
    private int WeekNumber => System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Now);

    protected override void OnInitialized()
    {
        if (!Auth.IsLoggedIn)
            Navigation.NavigateTo("/login");
        Theme.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("document.documentElement.setAttribute",
                "data-theme", Theme.IsDark ? "dark" : "light");
    }

    public void Dispose() => Theme.OnChange -= StateHasChanged;
}
